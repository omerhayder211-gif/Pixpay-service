PORT=3590
NODE_ENV=development
LOG_LEVEL=info

# Production Security Layer
API_KEY=
API_SECRET=
ALLOWED_ORIGIN=http://localhost:3000

# Rate Limiting & Sizing
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=60
MAX_REQUEST_SIZE=100kb

# Browser Display Settings
# Set to false to launch Chromium visibly for manual login via XRDP
BROWSER_HEADLESS=false
